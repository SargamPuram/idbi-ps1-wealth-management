# Copy this file to `.env` in the same folder (backend/.env) and fill in your key.
# The app uses python-dotenv to auto-load `.env` on startup — no shell exports needed.

# Google Gemini API key. Get one at https://aistudio.google.com/apikey
# Until this is set, /chat, market commentary, and spending-tip generation
# degrade gracefully (ai_powered: false) instead of crashing — every other
# endpoint (portfolio, suitability, goal-plan, products, insights, recommendations)
# works fully without it.
GEMINI_API_KEY=

# Optional: override the Gemini model. Defaults to gemini-2.5-flash (fast + cheap).
# If this model name errors for your key/account, run:
#   ./venv/Scripts/python -c "from google import genai; c=genai.Client(api_key='YOUR_KEY'); [print(m.name) for m in c.models.list()]"
# and pick a working model name from the printed list.
GEMINI_MODEL=gemini-2.5-flash
